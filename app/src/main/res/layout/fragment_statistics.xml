<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/DarkBlue"
    tools:context=".Stats.StatisticsFragment">

    <TextView
        android:id="@+id/tvHeaderStats"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/YourStatistics"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <ImageButton
        android:id="@+id/btnAdd"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="12dp"
        app:layout_constraintTop_toTopOf="@id/tvHeaderStats"
        app:layout_constraintBottom_toBottomOf="@id/tvHeaderStats"
        app:layout_constraintEnd_toEndOf="parent"
        android:src="@drawable/add"
        android:background="@color/Grey"/>

    <!-- Stat Cards -->
    <LinearLayout
        android:id="@+id/llStatsCards"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvHeaderStats"
        android:weightSum="3">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardBloodPressure"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_margin="12dp"
            app:cardCornerRadius="16dp"
            android:backgroundTint="@color/Grey">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/bloodpressure"/>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPulse"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_margin="12dp"
            app:cardCornerRadius="16dp"
            android:backgroundTint="@color/Grey">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/heartrate"/>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardHeartRate"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_margin="12dp"
            app:cardCornerRadius="16dp"
            android:backgroundTint="@color/Grey">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/pulse"/>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <!-- Scrollable LineChart -->
    <HorizontalScrollView
        android:id="@+id/hsvChart"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/llStatsCards">

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/lineChartStats"
            android:layout_width="12000dp"
            android:layout_height="match_parent"
            android:padding="16dp"/>
    </HorizontalScrollView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/CardStatInfo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/hsvChart"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:cardCornerRadius="16dp"
        android:backgroundTint="@color/Grey"
        app:strokeWidth="0dp"
        android:visibility="gone"
        />


</androidx.constraintlayout.widget.ConstraintLayout>
