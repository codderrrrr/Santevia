<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/DarkBlue"
    tools:context=".Stats.StatisticsFragment">

    <TextView
        android:id="@+id/tvHeaderStats"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/YourStatistics"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <ImageButton
        android:id="@+id/btnAdd"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="12dp"
        app:layout_constraintTop_toTopOf="@id/tvHeaderStats"
        app:layout_constraintBottom_toBottomOf="@id/tvHeaderStats"
        app:layout_constraintEnd_toEndOf="parent"
        android:src="@drawable/add"
        android:backgroundTint="#1B2735"
        app:tint="#00BFFF"/>

    <!-- Stat Cards -->
    <LinearLayout
        android:id="@+id/llStatsCards"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvHeaderStats"
        android:weightSum="3">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardWeight"
            android:layout_width="0dp"
            android:layout_height="105dp"
            android:layout_weight="1"
            android:layout_margin="8dp"
            app:cardCornerRadius="16dp"
            android:backgroundTint="#1B2735"
            app:cardElevation="6dp">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/weight"/>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardWater"
            android:layout_width="0dp"
            android:layout_height="105dp"
            android:layout_weight="1"
            android:layout_margin="8dp"
            app:cardCornerRadius="16dp"
            android:backgroundTint="#1B2735"
            app:cardElevation="6dp">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/water"/>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSleep"
            android:layout_width="0dp"
            android:layout_height="105dp"
            android:layout_weight="1"
            android:layout_margin="8dp"
            app:cardCornerRadius="16dp"
            android:backgroundTint="#1B2735"
            app:cardElevation="6dp">
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@drawable/sleep"/>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <ScrollView
        android:id="@+id/svChart"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="vertical"
        app:layout_constraintTop_toBottomOf="@id/llStatsCards"
        app:layout_constraintBottom_toBottomOf="parent"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/lineChartStats"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:background="@color/DarkBlue"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/CardStatInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="12dp"
                android:backgroundTint="#1B2735"
                android:padding="24dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginVertical="20dp">
                    <TextView
                        android:id="@+id/tvStatName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintRight_toRightOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"/>
                    <TextView
                        android:id="@+id/tvMax"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintRight_toRightOf="parent"
                        android:layout_marginTop="16dp"
                        app:layout_constraintTop_toBottomOf="@id/tvStatName"
                        android:textSize="72sp"
                        android:textStyle="bold"
                        android:textColor="@color/Red"/>
                    <TextView
                        android:id="@+id/tvMaxHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/maximum"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintRight_toRightOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvMax"
                        android:textColor="@color/white"/>
                    <TextView
                        android:id="@+id/tvMin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintRight_toLeftOf="@id/tvMode"
                        android:layout_marginTop="16dp"
                        app:layout_constraintTop_toBottomOf="@id/tvMaxHeader"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:textColor="#0BF40D"/>
                    <TextView
                        android:id="@+id/tvMinHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/minimum"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintRight_toLeftOf="@id/tvModeHeader"
                        app:layout_constraintTop_toBottomOf="@id/tvMin"
                        android:textColor="@color/white"/>
                    <TextView
                        android:id="@+id/tvMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintRight_toRightOf="parent"
                        app:layout_constraintLeft_toRightOf="@id/tvMin"
                        android:layout_marginTop="16dp"
                        app:layout_constraintTop_toBottomOf="@id/tvMaxHeader"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:textColor="#0BF40D"/>
                    <TextView
                        android:id="@+id/tvModeHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mode"
                        app:layout_constraintRight_toRightOf="parent"
                        app:layout_constraintLeft_toRightOf="@id/tvMinHeader"
                        app:layout_constraintTop_toBottomOf="@id/tvMin"
                        android:textColor="@color/white"/>
                    <TextView
                        android:id="@+id/tvMedian"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:layout_constraintRight_toRightOf="parent"
                        app:layout_constraintLeft_toLeftOf="parent"
                        android:layout_marginTop="16dp"
                        app:layout_constraintTop_toBottomOf="@id/tvMinHeader"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:textColor="#0BF40D"/>
                    <TextView
                        android:id="@+id/tvMedianHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/median"
                        app:layout_constraintRight_toRightOf="parent"
                        app:layout_constraintLeft_toLeftOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvMedian"
                        android:textColor="@color/white"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
