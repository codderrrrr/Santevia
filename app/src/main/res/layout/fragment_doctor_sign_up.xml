<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".Auth.DoctorSignUp">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/create_account"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvPersonalInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:hint="@string/personal_information"
            android:textColor="@color/black"
            android:padding="8dp"
            android:textSize="20sp"
            android:textColorHint="@color/black"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"/>

        <EditText
            android:id="@+id/etName"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/roundededittext"
            android:hint="@string/doctor_name"
            android:padding="12dp"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textColorHint="@color/black"
            app:layout_constraintTop_toBottomOf="@id/tvPersonalInfo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etUsername"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/roundededittext"
            android:hint="@string/Username"
            android:padding="16dp"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textColorHint="@color/black"
            app:layout_constraintTop_toBottomOf="@id/etName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/roundededittext"
            android:hint="@string/Password"
            android:padding="12dp"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textColorHint="@color/black"
            android:inputType="textPassword"
            app:layout_constraintTop_toBottomOf="@id/etUsername"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etVerifyPassword"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/roundededittext"
            android:hint="@string/VerifyPassword"
            android:padding="12dp"
            android:textColor="@color/black"
            android:textColorHint="@color/black"
            android:textSize="16sp"
            android:inputType="textPassword"
            app:layout_constraintTop_toBottomOf="@id/etPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etPhoneNo"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/roundededittext"
            android:hint="@string/phone"
            android:padding="12dp"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textColorHint="@color/black"
            app:layout_constraintTop_toBottomOf="@id/etVerifyPassword"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>


        <TextView
            android:id="@+id/tvWorkInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:hint="@string/work_info"
            android:textColor="@color/black"
            android:padding="8dp"
            android:textSize="20sp"
            android:textColorHint="@color/black"
            app:layout_constraintTop_toBottomOf="@id/etPhoneNo"
            app:layout_constraintStart_toStartOf="parent"/>

        <EditText
            android:id="@+id/etSpecialization"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/roundededittext"
            android:hint="@string/specialization_in_years"
            android:padding="12dp"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textColorHint="@color/black"
            app:layout_constraintTop_toBottomOf="@id/tvWorkInfo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etFees"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/roundededittext"
            android:hint="@string/fee_per_session"
            android:padding="12dp"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textColorHint="@color/black"
            app:layout_constraintTop_toBottomOf="@id/etSpecialization"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etHospital"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:hint="@string/current_hospital_name"
            android:padding="12dp"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:background="@drawable/roundededittext"
            android:textColorHint="@color/black"
            app:layout_constraintTop_toBottomOf="@id/etFees"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etExperience"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:hint="@string/experience_in_years"
            android:padding="12dp"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:background="@drawable/roundededittext"
            android:textColorHint="@color/black"
            app:layout_constraintTop_toBottomOf="@id/etHospital"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvEducation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:hint="@string/degrees"
            android:textColor="@color/black"
            android:padding="8dp"
            android:textSize="20sp"
            android:textColorHint="@color/black"
            app:layout_constraintTop_toBottomOf="@id/etExperience"
            app:layout_constraintStart_toStartOf="parent"/>

        <LinearLayout
            android:id="@+id/degreeContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/tvEducation"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddDegree"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/add_degree"
            android:layout_marginTop="12dp"
            android:backgroundTint="@color/Background"
            android:textColor="@color/black"
            app:cornerRadius="20dp"
            app:layout_constraintTop_toBottomOf="@id/degreeContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnSignUp"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_marginTop="24dp"
            android:text="@string/SignUp"
            android:textColor="@color/white"
            android:backgroundTint="@color/innerFill"
            app:cornerRadius="25dp"
            app:layout_constraintTop_toBottomOf="@id/btnAddDegree"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>